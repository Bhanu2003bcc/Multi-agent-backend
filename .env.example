# ──────────────────────────────────────────────────────────────────────────────
# .env — Copy this to .env and fill in real values before running docker-compose
# ──────────────────────────────────────────────────────────────────────────────

# ── Python Agent ──────────────────────────────────────────────────────────────
EXA_API_KEY=6778d992-513b-42f0-8feb-f8d55a30dbaa
OPENAI_API_KEY=your_openai_api_key_here

# ── Spring Boot JWT ───────────────────────────────────────────────────────────
# MUST be changed in production — minimum 64 characters
JWT_SECRET=change-this-in-production-must-be-at-least-64-chars-long-secret-key-here

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed Angular origins
CORS_ORIGINS=http://localhost:4200

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=admin123
